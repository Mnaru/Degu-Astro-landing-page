---
import type { GetStaticPaths } from 'astro';
import type { ImageMetadata } from 'astro';

import BaseLayout from '@layouts/BaseLayout.astro';

import { t } from '@i18n/utils';
import PhotoStack from '@components/gallery-detail/PhotoStack.astro';

export const getStaticPaths = (() => {
  const locales = ['en', 'lt'];
  const slugs = ['manilla', 'crocs', 'alita', 'mix', 'maxima'];

  return locales.flatMap(locale =>
    slugs.map(slug => ({
      params: { locale, slug },
    }))
  );
}) satisfies GetStaticPaths;

const { locale, slug } = Astro.params;
const i18n = t(locale);

const backgrounds: Record<string, string> = {
  manilla: '#6584A1',
  crocs: '#A5A196',
  alita: '#E2B032',
  mix: '#C70022',
  maxima: '#959CA6',
};

const bg = backgrounds[slug] ?? '#000000';
const galleryData = i18n.galleries[slug as keyof typeof i18n.galleries];
const galleryName = typeof galleryData === 'string' ? '' : galleryData.name;
const jobDone = typeof galleryData === 'string' ? '' : galleryData.jobDone;

const allGalleryImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/galleries/**/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

const images = Object.entries(allGalleryImages)
  .filter(([path]) => path.includes(`/galleries/${slug}/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, module]) => module.default);

const fitMode = slug === 'maxima' ? 'contain' : 'cover';
---

<BaseLayout
  title={`${galleryName} — Degu Studio`}
  description={`${galleryName} — ${jobDone}`}
  locale={locale}
  bodyStyle={`background-color: ${bg}; height: 100vh; overflow: hidden; touch-action: none;`}
>
  <div class="gallery-detail__bg" style={`background-color: ${bg};`}></div>
  <div class="gallery-detail">
    <div class="gallery-detail__header">
      <span class="gallery-detail__title">{galleryName}</span>
      <span class="gallery-detail__job-done">{jobDone}</span>
      <button class="gallery-detail__close" data-close-gallery data-locale={locale} data-slug={slug}>{i18n.galleries.close}</button>
    </div>
  </div>
  <PhotoStack images={images} galleryName={galleryName} fitMode={fitMode} />
  <script>
    import { navigate } from 'astro:transitions/client';

    document.addEventListener('astro:page-load', () => {
      const closeBtn = document.querySelector('[data-close-gallery]') as HTMLElement;
      if (!closeBtn) return;
      const locale = closeBtn.dataset.locale;

      closeBtn.addEventListener('click', () => {
        // Use history.back() when there's a previous page to go back to.
        // document.referrer is NOT updated by Astro's ClientRouter (pushState),
        // so we check the Navigation API or fall back to history.length.
        const nav = (window as any).navigation;
        const canGoBack = nav?.currentEntry
          ? nav.currentEntry.index > 0
          : history.length > 1;

        if (canGoBack) {
          history.back();
        } else {
          navigate(`/${locale}/`);
        }
      });
    });
  </script>
</BaseLayout>

<style>
  :global(html) {
    overflow: hidden;
  }

  .gallery-detail__bg {
    position: fixed;
    inset: 0;
    z-index: 1;
  }

  .gallery-detail {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: max(15px, calc(10px + 1.3888vw)) max(15px, calc(10px + 1.3888vw)) 0;
    box-sizing: border-box;
    color: #fff;
    font-family: inherit;
  }

  .gallery-detail__header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    position: relative;
    z-index: 50;
  }

  .gallery-detail__title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .gallery-detail__job-done {
    font-family: var(--font-body);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .gallery-detail__close {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: right;
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .gallery-detail__close:hover {
    opacity: 0.7;
  }

  @media (max-width: 1200px) {
    .gallery-detail__header {
      grid-template-columns: 1fr auto;
    }

    .gallery-detail__job-done {
      display: none;
    }
  }
</style>
