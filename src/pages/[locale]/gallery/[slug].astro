---
import type { GetStaticPaths } from 'astro';
import type { ImageMetadata } from 'astro';

import BaseLayout from '@layouts/BaseLayout.astro';

import { t } from '@i18n/utils';
import PhotoStack from '@components/gallery-detail/PhotoStack.astro';
import type { StackMedia } from '@components/gallery-detail/types';
import DeguLogo from '@components/DeguLogo.astro';

import eckesE02 from '@assets/images/galleries/eckes-granini/E_02.png';
import eckesE03 from '@assets/images/galleries/eckes-granini/E_03.png';
import eckesE05 from '@assets/images/galleries/eckes-granini/E_05.png';
import eckesE06 from '@assets/images/galleries/eckes-granini/E_06.png';
import eckesE08 from '@assets/images/galleries/eckes-granini/E_08.png';
import eckesE10 from '@assets/images/galleries/eckes-granini/E_10.png';
import eckesE12 from '@assets/images/galleries/eckes-granini/E_12.png';
import eckesE13 from '@assets/images/galleries/eckes-granini/E_13.png';
import eckesE14 from '@assets/images/galleries/eckes-granini/E_14.png';

export const getStaticPaths = (() => {
  const locales = ['en', 'lt'];
  const slugs = ['bottlery', 'manilla', 'eckes-granini', 'alita', 'open24', 'alita-2'];

  return locales.flatMap(locale =>
    slugs.map(slug => ({
      params: { locale, slug },
    }))
  );
}) satisfies GetStaticPaths;

const { locale, slug } = Astro.params;
const i18n = t(locale);

const backgrounds: Record<string, string> = {
  bottlery: '#E0948E',
  manilla: '#6584A1',
  'eckes-granini': '#EE8442',
  alita: '#3A1A29',
  open24: '#A5A196',
  'alita-2': '#E2B032',
};

const foregrounds: Record<string, string> = {};

const bg = backgrounds[slug] ?? '#000000';
const fg = foregrounds[slug] ?? '#ffffff';
const galleryData = i18n.galleries[slug as keyof typeof i18n.galleries];
const galleryName = typeof galleryData === 'string' ? '' : galleryData.name;
const jobDone = typeof galleryData === 'string' ? '' : galleryData.jobDone;

const allGalleryImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/galleries/**/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

const detailFilenamePatterns: Record<string, RegExp> = {
  bottlery: /\/B_[^/]+$/,
  manilla: /\/M_[^/]+$/,
  alita: /\/A_[^/]+$/,
  open24: /\/O_[^/]+$/,
  'alita-2': /\/A2_[^/]+$/,
};
const detailPattern = detailFilenamePatterns[slug];

const images = Object.entries(allGalleryImages)
  .filter(([path]) => path.includes(`/galleries/${slug}/`))
  .filter(([path]) => !detailPattern || detailPattern.test(path))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, module]) => module.default);

const mixedMedia: Record<string, StackMedia[]> = {
  'eckes-granini': [
    { kind: 'video', playbackId: 'ZjZlATUFk01g9dX8ILrKQ00wZqUVQipg79MBG6VXFFCJg' },
    { kind: 'image', src: eckesE02 },
    { kind: 'image', src: eckesE03 },
    { kind: 'video', playbackId: 'p5FIDPbd01cG00H1OPGbVR9wFIOKJ8IyEMWhqofPzIUPU' },
    { kind: 'image', src: eckesE05 },
    { kind: 'image', src: eckesE06 },
    { kind: 'video', playbackId: 'Y5eDdnqx5oUx3aS3mGFw101xZXnHD01CmXPKzRvK3WSrc' },
    { kind: 'image', src: eckesE08 },
    { kind: 'video', playbackId: 'JZiPb00hxLZ9X7P3D5FyoJ200qXe8Lg015NXYI4S7T01On00' },
    { kind: 'image', src: eckesE10 },
    { kind: 'video', playbackId: '14E5o7fTxLPNZLbgPSOHimIJ9o201y02HOR8X41gPV01H8' },
    { kind: 'image', src: eckesE12 },
    { kind: 'image', src: eckesE13 },
    { kind: 'image', src: eckesE14 },
  ],
};
const stackItems = mixedMedia[slug];

const fitMode = 'cover';
---

<BaseLayout
  title={`${galleryName} — Degu Studio`}
  description={`${galleryName} — ${jobDone}`}
  locale={locale}
  bodyStyle={`background-color: ${bg}; --gallery-bg: ${bg}; height: 100vh; overflow: hidden; touch-action: none;`}
>
  <div class="gallery-detail__bg" style={`background-color: ${bg};`}></div>
  <div class="gallery-detail" style={`color: ${fg};`}>
    <div class="gallery-detail__header">
      <span class="gallery-detail__title" transition:name={`gallery-name-${slug}`}>{galleryName}</span>
      <span class="gallery-detail__job-done">{jobDone}</span>
      <button class="gallery-detail__close" data-close-gallery data-locale={locale} data-slug={slug}>{i18n.galleries.close}</button>
    </div>
  </div>
  <div class="gallery-detail__end-logo" data-end-logo data-logo-no-click aria-hidden="true">
    <DeguLogo />
  </div>
  {stackItems
    ? <PhotoStack items={stackItems} galleryName={galleryName} fitMode={fitMode} slug={slug} />
    : <PhotoStack images={images} galleryName={galleryName} fitMode={fitMode} slug={slug} />
  }
  {/* Hidden anchors so transition:persist actually works bidirectionally.
      Astro requires the directive on both source and destination — without
      these, the home gallery wrapper is discarded on home → detail, and
      return navigation re-renders fresh (visibly painting in on mobile). */}
  <div style="display: none;" aria-hidden="true">
    <div class="galleries-wrapper" transition:persist={`galleries-${locale}`}></div>
    <div class="gallery-cursor" transition:persist={`gallery-cursor-${locale}`}></div>
  </div>
  <script>
    import { navigate } from 'astro:transitions/client';

    document.addEventListener('astro:page-load', () => {
      const closeBtn = document.querySelector('[data-close-gallery]') as HTMLElement;
      if (!closeBtn) return;
      const locale = closeBtn.dataset.locale;

      const closeGallery = () => {
        const nav = (window as any).navigation;
        const canGoBack = nav?.currentEntry
          ? nav.currentEntry.index > 0
          : history.length > 1;

        if (canGoBack) {
          history.back();
        } else {
          navigate(`/${locale}/`);
        }
      };

      closeBtn.addEventListener('click', closeGallery);

      const bg = document.querySelector<HTMLElement>('.gallery-detail__bg');
      const endLogo = document.querySelector<HTMLElement>('[data-end-logo]');
      // PhotoStack is persisted across navigation, so on a return visit
      // the container may already carry .photo-stack--complete from a
      // previous swipe-through. Reflect that state in the (fresh) endLogo.
      const stack = document.querySelector('.photo-stack');
      let complete = stack?.classList.contains('photo-stack--complete') ?? false;
      if (complete) endLogo?.classList.add('gallery-detail__end-logo--visible');

      const onComplete = () => {
        complete = true;
        endLogo?.classList.add('gallery-detail__end-logo--visible');
      };

      const onMaybeClose = () => {
        if (complete) closeGallery();
      };

      document.addEventListener('photostack:complete', onComplete);
      bg?.addEventListener('click', onMaybeClose);
      endLogo?.addEventListener('click', onMaybeClose);
    });
  </script>
</BaseLayout>

<style>
  :global(html) {
    overflow: hidden;
  }

  .gallery-detail__bg {
    position: fixed;
    inset: 0;
    z-index: 1;
  }

  .gallery-detail__end-logo {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease-out;
  }

  .gallery-detail__end-logo--visible {
    opacity: 1;
    pointer-events: auto;
  }

  .gallery-detail__end-logo :global(.flame-svg) {
    height: clamp(50px, 9vh, 100px);
    width: auto;
  }

  .gallery-detail {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: max(15px, calc(10px + 1.3888vw)) max(15px, calc(10px + 1.3888vw)) 0;
    box-sizing: border-box;
    color: #fff;
    font-family: inherit;
  }

  .gallery-detail__header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    position: relative;
    z-index: 50;
  }

  .gallery-detail__title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .gallery-detail__job-done {
    display: none;
  }

  .gallery-detail__close {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: right;
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .gallery-detail__close:hover {
    opacity: 0.7;
  }

</style>
