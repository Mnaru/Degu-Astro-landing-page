---
import type { GetStaticPaths } from 'astro';

import BaseLayout from '@layouts/BaseLayout.astro';

import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import HeaderContainer from '@components/HeaderContainer.astro';
import HeaderContainerStudio from '@components/HeaderContainerStudio.astro';
import BodyTextContainer from '@components/BodyTextContainer.astro';
import ScrollHint from '@components/ScrollHint.astro';

import BottleryGallery from '@components/galleries/BottleryGallery.astro';
import ManillaGallery from '@components/galleries/ManillaGallery.astro';
import EckesGraniniGallery from '@components/galleries/EckesGraniniGallery.astro';
import AlitaGallery from '@components/galleries/AlitaGallery.astro';
import Open24Gallery from '@components/galleries/Open24Gallery.astro';
import Alita2Gallery from '@components/galleries/Alita2Gallery.astro';

import AboutVideo from '@components/AboutVideo.astro';
import CrossedTicker from '@components/CrossedTicker.astro';
import Footer from '@components/Footer.astro';

import { t } from '@i18n/utils';

export const getStaticPaths = (() => {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'lt' } },
  ];
}) satisfies GetStaticPaths;

const { locale } = Astro.params;
const i18n = t(locale);
---

<BaseLayout title={i18n.meta.title} description={i18n.meta.description} locale={locale}>
  <Header locale={locale} />
  <Hero>
    <HeaderContainer text={i18n.intro.header1} />
    <div class="hero-row">
      <HeaderContainerStudio text={i18n.intro.header2} />
      <BodyTextContainer text={i18n.intro.body} />
    </div>
    <ScrollHint>{i18n.intro.scrollHint}</ScrollHint>
  </Hero>

  <div class="galleries-wrapper" data-gsap transition:persist={`galleries-${locale}`}>
    <BottleryGallery locale={locale} />
    <ManillaGallery locale={locale} />
    <EckesGraniniGallery locale={locale} />
    <AlitaGallery locale={locale} />
    <Open24Gallery locale={locale} />
    <Alita2Gallery locale={locale} />
  </div>

  <div class="gallery-cursor" aria-hidden="true" transition:persist={`gallery-cursor-${locale}`}>
    <span class="gallery-cursor__label">{i18n.galleries.view}</span>
  </div>

  <AboutVideo locale={locale} />

  <CrossedTicker locale={locale} />

  <Footer locale={locale} />

  <script>
    import { initGallerySkew } from '@lib/animations/gallerySkew';
    import { initGalleryCursor } from '@lib/animations/galleryCursor';
    import { registerCleanup } from '@lib/animations/lifecycle';

    document.addEventListener('astro:page-load', () => {
      const galleries = Array.from(
        document.querySelectorAll('[data-gallery]')
      ) as HTMLElement[];

      // Galleries are persisted across navigation. Skip re-init if already initialized.
      const galleriesWrapper = document.querySelector('.galleries-wrapper') as any;
      if (galleries.length > 0 && !galleriesWrapper?.__skewInit) {
        if (galleriesWrapper) galleriesWrapper.__skewInit = true;
        registerCleanup(initGallerySkew({ elements: galleries }), { persistent: true });
      }

      const cursor = document.querySelector('.gallery-cursor') as HTMLElement | null;
      const links = Array.from(
        document.querySelectorAll('.gallery__link')
      ) as HTMLElement[];
      if (cursor && links.length > 0 && !(cursor as any).__cursorInit) {
        (cursor as any).__cursorInit = true;
        registerCleanup(initGalleryCursor({ cursor, links }), { persistent: true });
      }
    });
  </script>

  <style>
    .galleries-wrapper {
      padding-bottom: clamp(96px, 14vw, 240px);
    }

    .gallery-cursor {
      position: fixed;
      top: 0;
      left: 0;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: var(--color-orange);
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      visibility: hidden;
      z-index: 1000;
      will-change: transform, opacity;
    }

    .gallery-cursor__label {
      color: var(--color-white);
      font-family: var(--font-body);
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0;
      line-height: 1;
    }

    @media (hover: hover) {
      :global(.galleries-wrapper .gallery__link) {
        cursor: none;
      }
    }

    @media (hover: none), (max-width: 1200px) {
      .gallery-cursor {
        display: none;
      }
    }
  </style>
</BaseLayout>
