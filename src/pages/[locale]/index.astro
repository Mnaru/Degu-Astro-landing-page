---
import type { GetStaticPaths } from 'astro';

import BaseLayout from '@layouts/BaseLayout.astro';

import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import HeaderContainer from '@components/HeaderContainer.astro';
import HeaderContainerStudio from '@components/HeaderContainerStudio.astro';
import BodyTextContainer from '@components/BodyTextContainer.astro';
import ScrollHint from '@components/ScrollHint.astro';

import ManillaGallery from '@components/galleries/ManillaGallery.astro';
import CrocsGallery from '@components/galleries/CrocsGallery.astro';
import AlitaGallery from '@components/galleries/AlitaGallery.astro';
import MixGallery from '@components/galleries/MixGallery.astro';
import MaximaGallery from '@components/galleries/MaximaGallery.astro';

import Review from '@components/Review.astro';
import Outro from '@components/Outro.astro';
import OutroHeaderContainer from '@components/OutroHeaderContainer.astro';
import OutroStudioContainer from '@components/OutroStudioContainer.astro';
import OutroBodyTextContainer from '@components/OutroBodyTextContainer.astro';
import EmailUsButton from '@components/EmailUsButton.astro';
import FollowUsButton from '@components/FollowUsButton.astro';
import Footer from '@components/Footer.astro';

import { t } from '@i18n/utils';

export const getStaticPaths = (() => {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'lt' } },
  ];
}) satisfies GetStaticPaths;

const { locale } = Astro.params;
const i18n = t(locale);
---

<BaseLayout title={i18n.meta.title} description={i18n.meta.description} locale={locale}>
  <Header locale={locale} />
  <Hero>
    <HeaderContainer text={i18n.intro.header1} />
    <div class="hero-row">
      <HeaderContainerStudio text={i18n.intro.header2} />
      <BodyTextContainer text={i18n.intro.body} />
    </div>
    <ScrollHint>{i18n.intro.scrollHint}</ScrollHint>
  </Hero>

  <div class="galleries-wrapper" data-gsap>
    <ManillaGallery locale={locale} />
    <CrocsGallery locale={locale} />
    <AlitaGallery locale={locale} />
    <MixGallery locale={locale} />
    <MaximaGallery locale={locale} />
  </div>

  <Review locale={locale} />

  <Footer locale={locale} />

  <!-- <Outro locale={locale}>
    <div class="outro-content">
      <OutroHeaderContainer text={i18n.outro.header1} />
      <OutroStudioContainer text={i18n.outro.header2} />
      <OutroBodyTextContainer text={i18n.outro.body} class="outro-body" />
      <div class="outro-buttons">
        <EmailUsButton label={i18n.outro.emailButton} feedbackText={i18n.outro.emailCopied} />
        <FollowUsButton label={i18n.outro.followButton} />
      </div>
    </div>
  </Outro> -->
  <script>
    import { initGallerySkew } from '@lib/animations/gallerySkew';
    import { registerCleanup } from '@lib/animations/lifecycle';

    document.addEventListener('astro:page-load', () => {
      const galleries = Array.from(
        document.querySelectorAll('[data-gallery]')
      ) as HTMLElement[];

      if (galleries.length > 0) {
        registerCleanup(initGallerySkew({ elements: galleries }));
      }
    });
  </script>
</BaseLayout>
