---
import type { GetStaticPaths } from 'astro';

import '../../styles/global.css';
import { t } from '@i18n/utils';
import Outro from '@components/Outro.astro';
import OutroHeaderContainer from '@components/OutroHeaderContainer.astro';
import OutroStudioContainer from '@components/OutroStudioContainer.astro';
import OutroBodyTextContainer from '@components/OutroBodyTextContainer.astro';
import EmailUsButton from '@components/EmailUsButton.astro';
import FollowUsButton from '@components/FollowUsButton.astro';

export const getStaticPaths = (() => {
  return [
    { params: { locale: 'lt' } },
  ];
}) satisfies GetStaticPaths;

const { locale } = Astro.params;
const i18n = t(locale);
---

<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Outro Test</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton+SC&family=Instrument+Serif:ital@1&family=Public+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Outro>
      <div class="outro-content">
        <OutroHeaderContainer text={i18n.outro.header1} />
        <OutroStudioContainer text={i18n.outro.header2} />
        <OutroBodyTextContainer text={i18n.outro.body} class="outro-body" />
        <div class="outro-buttons">
          <EmailUsButton label={i18n.outro.emailButton} />
          <FollowUsButton />
        </div>
      </div>
    </Outro>
  </body>
</html>

<style>
  body {
    background: var(--color-black);
  }

  .outro-content {
    width: fit-content;
    margin-inline: auto;
  }

  @media (max-width: 400px) {
    .outro-content {
      margin-inline: 0;
    }
  }

  .outro-body {
    margin-top: clamp(24px, calc(432px - 28.333vw), 330px);
  }

  .outro-buttons {
    display: flex;
    flex-direction: row;
    gap: 12px;
    margin-top: 27px;
  }

</style>
