---
import type { HTMLAttributes } from 'astro/types';
import { Image } from 'astro:assets';
import { t } from '@i18n/utils';
import brandImage from '@assets/images/Footer image.png';

interface Props extends HTMLAttributes<'footer'> {
  locale: string;
  class?: string;
}

const { locale, class: className, ...attrs } = Astro.props;
const i18n = t(locale);
---

<footer class:list={['footer', className]} aria-label="Site footer" {...attrs}>
  <div class="footer__content-grid">
    <h2 class="footer__heading">{i18n.footer.heading}</h2>

    <div class="footer__columns">
      <div class="footer__col">
        <p class="footer__col-label footer__col-label--with-arrow">
          <span aria-hidden="true">&#x2197;</span>
          {i18n.footer.contactLabel}
        </p>
        <a href={`mailto:${i18n.footer.email}`} class="footer__email-link">{i18n.footer.email}</a>
      </div>

      <nav class="footer__col" aria-label={i18n.footer.connectLabel}>
        <p class="footer__col-label">{i18n.footer.connectLabel}</p>
        <ul class="footer__link-list">
          <li><a href="https://www.instagram.com/degu_studio/" target="_blank" rel="noopener noreferrer">{i18n.footer.instagram}</a></li>
          <li><a href="#" target="_blank" rel="noopener noreferrer">{i18n.footer.linkedin}</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <div class="footer__legal-row">
    <p class="footer__copyright">
      {i18n.footer.copyrightPrefix}<a href="https://www.instagram.com/monikanarusyte/" target="_blank" rel="noopener noreferrer" class="footer__monika-link">@Monika</a>{i18n.footer.copyrightSuffix}
    </p>
    <p class="footer__location">{i18n.footer.location}</p>
  </div>

  <Image
    src={brandImage}
    alt={i18n.footer.brandImageAlt}
    width={4320}
    height={720}
    loading="lazy"
    format="webp"
    class="footer__brand-image"
  />
</footer>

<style>
  .footer {
    position: relative;
    z-index: 2;
    margin-top: calc(170px - 30vh);
  }

  /* ── Content Grid ── */

  .footer__content-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 max(15px, calc(10px + 1.389vw)) 120px;
  }

  .footer__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 400;
    line-height: 1;
    color: var(--color-offwhite);
    margin: 0 0 40px;
  }

  .footer__columns {
    display: flex;
    gap: 80px;
    justify-content: center;
  }

  .footer__col {
    /* Flex column with explicit gap so the label-to-content distance is
       identical between the contact column (label is inline-flex with arrow)
       and the connect column (label is plain block). Mixing block + inline-flex
       previously caused subtle line-box differences that made the gaps look
       unequal even at matching margins.
       text-align: left explicitly overrides the inherited center from
       .footer__content-grid — without it, link-list items get centered
       within their <li> width and drift off the left edge. */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    text-align: left;
  }

  .footer__col-label {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-offwhite);
    margin: 0;
  }

  .footer__col-label--with-arrow {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer__email-link {
    display: block;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 1.32px;
    text-transform: uppercase;
    color: var(--color-offwhite);
    text-decoration: none;
  }

  .footer__link-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    /* Negative margin-top nudges the list up to optically match the
       label-to-email gap in the contact column. Pure spacing adjustment;
       the value is empirical, not derived from font metrics. */
    margin: -1px 0 0;
    padding: 0;
    /* Match the email link's font metrics so the first link's line-box
       (= font-size × line-height) is identical. */
    font-size: 14px;
    line-height: 1.2;
  }

  .footer__link-list a {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 1.32px;
    text-transform: uppercase;
    color: var(--color-offwhite);
    text-decoration: none;
  }

  .footer__email-link:hover,
  .footer__link-list a:hover,
  .footer__monika-link:hover {
    color: var(--color-orange);
  }

  /* ── Legal Row ── */

  .footer__legal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px max(15px, calc(10px + 1.389vw));
  }

  .footer__copyright,
  .footer__location {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-offwhite);
    margin: 0;
  }

  .footer__monika-link {
    color: var(--color-offwhite);
    text-decoration: none;
  }

  /* ── Brand Image ── */

  .footer__brand-image {
    width: 100%;
    height: auto;
    display: none; /* TODO: re-enable */
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .footer__columns {
      flex-direction: column;
      gap: 32px;
      align-items: center;
    }

    .footer__col {
      align-items: center;
      text-align: center;
    }
  }

  @media (max-width: 1024px) {
    .footer__legal-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
