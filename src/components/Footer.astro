---
import type { HTMLAttributes } from 'astro/types';
import { t } from '@i18n/utils';

interface Props extends HTMLAttributes<'footer'> {
  locale: string;
  class?: string;
}

const { locale, class: className, ...attrs } = Astro.props;
const i18n = t(locale);
---

<footer class:list={['footer', className]} {...attrs}>
  <!-- Row 1: Contact & Location -->
  <div class="footer__row footer__row--padded">
    <div class="footer__contacts">
      <button
        class="footer__btn"
        aria-label={`${i18n.footer.email} — monika@nuar.app`}
        data-email="monika@nuar.app"
        data-label={i18n.footer.email}
      >
        <span class="footer__btn-label">{i18n.footer.email}</span>
      </button>
      <button
        class="footer__btn"
        aria-label={i18n.footer.instagram}
        data-href="https://www.instagram.com/degu.studio/"
      >
        <span class="footer__btn-label">{i18n.footer.instagram}</span>
      </button>
    </div>
    <span class="footer__location">
      <span class="footer__location-short">{i18n.footer.locationShort}</span>
      <span class="footer__location-full">{i18n.footer.location}</span>
    </span>
  </div>

  <!-- Row 2: Marquee -->
  <div class="footer__row footer__marquee-wrapper" aria-hidden="true">
    <div class="footer__marquee">
      <span class="footer__marquee-text">DEGU STUDIO</span>
      <span class="footer__marquee-text">DEGU STUDIO</span>
      <span class="footer__marquee-text">DEGU STUDIO</span>
      <span class="footer__marquee-text">DEGU STUDIO</span>
    </div>
  </div>

  <!-- Row 3: Copyright & Credits -->
  <div class="footer__row footer__row--padded footer__bottom">
    <span class="footer__copyright">{i18n.footer.copyright}</span>
    <button
      class="footer__btn"
      aria-label={i18n.footer.siteBy}
      data-href="https://www.instagram.com/monikanarusyte"
    >
      <span class="footer__btn-label">{i18n.footer.siteBy}</span>
    </button>
  </div>
</footer>

<script>
  document.addEventListener('astro:page-load', () => {
    const footer = document.querySelector('.footer');
    if (!footer) return;

    // Email buttons
    footer.querySelectorAll<HTMLButtonElement>('[data-email]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const email = btn.dataset.email ?? '';
        const label = btn.dataset.label ?? '';
        const labelEl = btn.querySelector('.footer__btn-label');
        if (!labelEl) return;

        try {
          await navigator.clipboard.writeText(email);
        } catch {
          const textarea = document.createElement('textarea');
          textarea.value = email;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
        }

        labelEl.textContent = '💚';
        btn.classList.add('copied');
        setTimeout(() => {
          labelEl.textContent = label;
          btn.classList.remove('copied');
        }, 3000);
      });
    });

    // Link buttons
    footer.querySelectorAll<HTMLButtonElement>('[data-href]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const href = btn.dataset.href ?? '';
        window.open(href, '_blank', 'noopener,noreferrer');
      });
    });
  });
</script>

<style>
  .footer {
    position: relative;
    z-index: 1;
    background: var(--color-offwhite);
    padding: 32px 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer__row--padded {
    padding-left: max(15px, calc(10px + 1.389vw));
    padding-right: max(15px, calc(10px + 1.389vw));
  }

  .footer__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Row 1 */
  .footer__contacts {
    display: flex;
    gap: 24px;
  }

  .footer__location {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-black);
  }

  .footer__location-full {
    display: inline;
  }

  .footer__location-short {
    display: none;
  }

  @media (max-width: 480px) {
    .footer__location-full {
      display: none;
    }

    .footer__location-short {
      display: inline;
    }
  }

  /* Buttons */
  .footer__btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  @media (hover: hover) {
    .footer__btn:hover .footer__btn-label {
      color: var(--color-orange);
    }

    .footer__btn:hover {
      color: var(--color-orange);
    }
  }

  .footer__btn:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 2px;
  }

  .footer__btn-label {
    color: var(--color-black);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    line-height: normal;
    letter-spacing: 0;
    transition: color 0.2s ease;
  }

  /* Row 2: Marquee */
  .footer__marquee-wrapper {
    overflow: hidden;
    width: 100%;
    margin-top: -166px;
    margin-bottom: -30px;
  }

  .footer__marquee {
    display: flex;
    width: max-content;
    animation: marquee 12s linear infinite;
    word-spacing: 0.3em;
  }

  .footer__marquee-text::after {
    content: '\00a0';
  }

  .footer__marquee-text {
    font-family: var(--font-display);
    font-size: max(400px, calc(360px + 11.111vw));
    line-height: 1.15;
    color: var(--color-black);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__marquee {
      animation: none;
    }
  }

  /* Row 3 */
  .footer__bottom {
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer__copyright {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-black);
  }
</style>
