---
interface Props {
  text: string;
  subtext?: string;
}

const { text, subtext } = Astro.props;
---

<div class="gallery-label">
  <span class="gallery-label-text" set:html={text} />
  {subtext && <span class="gallery-label-subtext" set:html={subtext} />}
</div>


<style>
  .gallery-label {
  }

  .gallery-label-text {
    color: var(--color-black);
    font-family: "Anton SC";
    font-size: max(50px, calc(32.33px + 4.907vw));
    font-style: normal;
    font-weight: 400;
    line-height: max(46px, calc(29.83px + 4.526vw));
    text-transform: uppercase;
  }

  .gallery-label-subtext {
    display: inline-block;
    vertical-align: baseline;
    margin-left: 24px;
    color: var(--color-black);
    font-family: "Instrument Serif";
    font-size: max(18px, calc(11.67px + 1.759vw));
    font-style: italic;
    font-weight: 400;
    line-height: 1;
  }
</style>
