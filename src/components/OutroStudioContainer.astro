---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  text: string;
  class?: string;
}

const { text, class: className, ...attrs } = Astro.props;
---

<div class:list={['outro-studio-container', className]} {...attrs}>
  <span class="outro-studio-text">{text}</span>
</div>

<style>
  .outro-studio-container {
    width: fit-content;
    margin-top: calc(-3.6px - 1vw);
  }

  .outro-studio-text {
    display: block;
    font-family: var(--font-display);
    font-size: max(70px, calc(34.33px + 9.907vw));
    font-style: normal;
    font-weight: 400;
    line-height: 1;
    text-align: left;
    text-transform: uppercase;
    color: var(--color-offwhite);
    white-space: nowrap;
    text-box-trim: both;
    text-box-edge: cap;
  }
</style>
