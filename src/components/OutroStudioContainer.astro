---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  text: string;
  class?: string;
}

const { text, class: className, ...attrs } = Astro.props;
---

<div class:list={['outro-studio-container', className]} {...attrs}>
  <span class="outro-studio-text">{text}</span>
</div>

<style>
  .outro-studio-container {
    width: fit-content;
    margin-top: calc(8.67px + 0.926vw);
  }

  .outro-studio-text {
    display: block;
    font-family: var(--font-display);
    font-size: max(120px, calc(101px + 5.278vw));
    font-style: normal;
    font-weight: 400;
    line-height: 0.75;
    text-align: left;
    text-transform: uppercase;
    color: var(--color-offwhite);
    white-space: nowrap;
    text-box-trim: both;
    text-box-edge: cap;
  }
</style>
