---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import type { StackMedia } from './types';

interface Props {
  images?: ImageMetadata[];
  items?: StackMedia[];
  galleryName: string;
  fitMode?: 'cover' | 'contain';
}

const { images, items, galleryName, fitMode = 'cover' } = Astro.props;

const media: StackMedia[] =
  items ??
  (images ?? []).map((img) => ({ kind: 'image', src: img }));

const hasVideo = media.some((m) => m.kind === 'video');

// Desktop: strong horizontal spread, moderate vertical
const desktopOffsets = [
  { x: 0,    y: 0   },
  { x: 90,   y: 10  },
  { x: -75,  y: 16  },
  { x: 115,  y: -8  },
  { x: -100, y: 12  },
  { x: 80,   y: 22  },
  { x: -120, y: 6   },
  { x: 105,  y: -12 },
  { x: -85,  y: 18  },
  { x: 130,  y: 10  },
  { x: -95,  y: -10 },
  { x: 100,  y: 24  },
];

// Mobile: vertical spread, moderate horizontal
const mobileOffsets = [
  { x: 0,   y: 0   },
  { x: 24,  y: 40  },
  { x: -18, y: 65  },
  { x: 30,  y: -28 },
  { x: -26, y: 55  },
  { x: 18,  y: 76  },
  { x: -34, y: 32  },
  { x: 28,  y: -42 },
  { x: -20, y: 70  },
  { x: 36,  y: 48  },
  { x: -30, y: -32 },
  { x: 22,  y: 82  },
];

function getOffset(offsets: typeof desktopOffsets, index: number, axis: 'x' | 'y'): number {
  if (index >= offsets.length) {
    if (axis === 'x') return ((index % 2 === 0) ? 1 : -1) * (3 + (index % 5) * 2);
    return 2 + (index % 4) * 2;
  }
  return offsets[index][axis];
}
---

<div class="photo-stack" data-photo-stack data-fit-mode={fitMode} data-has-video={hasVideo ? 'true' : 'false'} style={`--fit-mode: ${fitMode};`}>
  {media.map((item, index) => (
    <div
      class:list={['photo-stack__card', { 'photo-stack__card--base': index === 0, 'photo-stack__card--video': item.kind === 'video', 'photo-stack__card--covered': index > 0 }]}
      data-card-index={index}
      style={`--offset-x-d: ${getOffset(desktopOffsets, index, 'x')}px; --offset-y-d: ${getOffset(desktopOffsets, index, 'y')}px; --offset-x-m: ${getOffset(mobileOffsets, index, 'x')}px; --offset-y-m: ${getOffset(mobileOffsets, index, 'y')}px; z-index: ${media.length - index};`}
    >
      <div class="photo-stack__card-inner">
        {item.kind === 'image' ? (
          <Image
            src={item.src}
            alt={`${galleryName} ${index + 1}`}
            width={1200}
            height={800}
            loading={index < 3 ? 'eager' : 'lazy'}
            decoding="async"
            {...(index === 0 ? { fetchpriority: 'high' } : {})}
          />
        ) : (
          <mux-video
            playback-id={item.playbackId}
            poster={`https://image.mux.com/${item.playbackId}/thumbnail.webp?time=0`}
            loop
            playsinline
            preload="auto"
            muted
            aria-label={`${galleryName} video ${index + 1}`}
          ></mux-video>
        )}
      </div>
    </div>
  ))}
</div>

<style>
  .photo-stack {
    position: fixed;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: max(320px, calc(255.33px + 17.96vw));
    max-width: 90vw;
    width: auto;
    z-index: 10;
  }

  .photo-stack--complete {
    pointer-events: none;
  }

  .photo-stack[data-fit-mode='contain'] {
    top: 53%;
  }

  @media (min-width: 1201px) {
    .photo-stack {
      top: 52%;
    }

    .photo-stack[data-fit-mode='contain'] {
      top: 52%;
    }
  }

  .photo-stack__card {
    opacity: 0;
  }

  .photo-stack__card-inner {
    position: relative;
  }

  .photo-stack__card-inner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gallery-bg, #000);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease-out;
    z-index: 20;
  }

  .photo-stack__card--covered .photo-stack__card-inner::after {
    opacity: 0.6;
  }

  .photo-stack__card--base {
    position: relative;
    transform: none;
    height: 100%;
    width: auto;
  }

  .photo-stack__card--base.photo-stack__card--video {
    width: calc((4 / 5) * max(320px, calc(255.33px + 17.96vw)));
  }

  .photo-stack__card-inner {
    width: 100%;
    height: 100%;
    overflow: hidden;
    --pulse-scale: 1;
    --proximity-scale: 1;
    scale: calc(var(--pulse-scale) * var(--proximity-scale));
  }

  .photo-stack__card--base .photo-stack__card-inner img {
    height: 100%;
    width: auto;
    display: block;
  }

  .photo-stack__card:not(.photo-stack__card--base) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    --offset-x: var(--offset-x-m);
    --offset-y: var(--offset-y-m);
    transform: translate(var(--offset-x), var(--offset-y));
  }

  @media (min-width: 1201px) {
    .photo-stack__card:not(.photo-stack__card--base) {
      --offset-x: var(--offset-x-d);
      --offset-y: var(--offset-y-d);
    }
  }

  .photo-stack__card:not(.photo-stack__card--base) .photo-stack__card-inner img {
    width: 100%;
    height: 100%;
    object-fit: var(--fit-mode, cover);
    object-position: center;
    display: block;
  }

  .photo-stack__card-inner mux-video {
    display: block;
    width: 100%;
    height: 100%;
    --media-object-fit: var(--fit-mode, cover);
    --media-object-position: center;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { initPhotoStack } from '@lib/animations/photoStack';
  import { initPhotoPulse } from '@lib/animations/photoPulse';
  import { initPhotoProximity } from '@lib/animations/photoProximity';
  import { registerCleanup } from '@lib/animations/lifecycle';

  document.addEventListener('astro:page-load', async () => {
    const container = document.querySelector('[data-photo-stack]') as HTMLElement;
    if (container?.dataset.hasVideo === 'true') {
      await import('@mux/mux-video');
    }
    const cards = Array.from(
      container?.querySelectorAll('.photo-stack__card') ?? []
    ) as HTMLElement[];
    const cardInners = Array.from(
      container?.querySelectorAll('.photo-stack__card-inner') ?? []
    ) as HTMLElement[];

    if (container && cards.length > 0) {
      gsap.fromTo(cards, { opacity: 0, scale: 0.97 }, {
        opacity: 1, scale: 1, duration: 0.5, ease: 'power2.out', stagger: 0.05,
        onComplete: () => cards.forEach(card => gsap.set(card, { clearProps: 'scale' })),
      });

      const getVideo = (card: HTMLElement | undefined) =>
        card?.querySelector('mux-video') as (HTMLElement & { play?: () => Promise<void>; pause?: () => void }) | null;

      const onTopCardChange = (newIndex: number, prevIndex: number) => {
        const prev = getVideo(cards[prevIndex]);
        prev?.pause?.();
        const next = getVideo(cards[newIndex]);
        next?.play?.().catch(() => {});
        cards[newIndex]?.classList.remove('photo-stack__card--covered');
        if (newIndex >= cards.length) {
          container.classList.add('photo-stack--complete');
          container.dispatchEvent(new CustomEvent('photostack:complete', { bubbles: true }));
        }
      };

      registerCleanup(initPhotoStack({ container, cards, onTopCardChange }));
      registerCleanup(initPhotoPulse({ cards: cardInners }));
      registerCleanup(initPhotoProximity({ cards: cardInners }));
    }
  });
</script>
