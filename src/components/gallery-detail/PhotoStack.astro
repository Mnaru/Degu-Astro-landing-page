---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
  galleryName: string;
  fitMode?: 'cover' | 'contain';
}

const { images, galleryName, fitMode = 'cover' } = Astro.props;

// Desktop: strong horizontal spread, moderate vertical
const desktopOffsets = [
  { x: 0,    y: 0   },
  { x: 90,   y: 10  },
  { x: -75,  y: 16  },
  { x: 115,  y: -8  },
  { x: -100, y: 12  },
  { x: 80,   y: 22  },
  { x: -120, y: 6   },
  { x: 105,  y: -12 },
  { x: -85,  y: 18  },
  { x: 130,  y: 10  },
  { x: -95,  y: -10 },
  { x: 100,  y: 24  },
];

// Mobile: vertical spread, moderate horizontal
const mobileOffsets = [
  { x: 0,   y: 0   },
  { x: 24,  y: 40  },
  { x: -18, y: 65  },
  { x: 30,  y: -28 },
  { x: -26, y: 55  },
  { x: 18,  y: 76  },
  { x: -34, y: 32  },
  { x: 28,  y: -42 },
  { x: -20, y: 70  },
  { x: 36,  y: 48  },
  { x: -30, y: -32 },
  { x: 22,  y: 82  },
];

function getOffset(offsets: typeof desktopOffsets, index: number, axis: 'x' | 'y'): number {
  if (index >= offsets.length) {
    if (axis === 'x') return ((index % 2 === 0) ? 1 : -1) * (3 + (index % 5) * 2);
    return 2 + (index % 4) * 2;
  }
  return offsets[index][axis];
}
---

<div class="photo-stack" data-photo-stack style={`--fit-mode: ${fitMode};`}>
  {images.map((img, index) => (
    <div
      class:list={['photo-stack__card', { 'photo-stack__card--base': index === 0 }]}
      data-card-index={index}
      style={`--offset-x-d: ${getOffset(desktopOffsets, index, 'x')}px; --offset-y-d: ${getOffset(desktopOffsets, index, 'y')}px; --offset-x-m: ${getOffset(mobileOffsets, index, 'x')}px; --offset-y-m: ${getOffset(mobileOffsets, index, 'y')}px; z-index: ${images.length - index};`}
    >
      <div class="photo-stack__card-inner">
        <Image
          src={img}
          alt={`${galleryName} ${index + 1}`}
          width={1200}
          height={800}
          loading={index < 3 ? 'eager' : 'lazy'}
          decoding="async"
          {...(index === 0 ? { fetchpriority: 'high' } : {})}
        />
      </div>
    </div>
  ))}
</div>

<style>
  .photo-stack {
    position: fixed;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: max(320px, calc(255.33px + 17.96vw));
    max-width: 90vw;
    width: auto;
    z-index: 10;
  }

  @media (min-width: 1201px) {
    .photo-stack {
      top: 52%;
    }
  }

  .photo-stack__card {
    opacity: 0;
    animation: cardIn 0.3s ease-out forwards;
  }

  .photo-stack__card:nth-child(1) { animation-delay: 0.05s; }
  .photo-stack__card:nth-child(2) { animation-delay: 0.08s; }
  .photo-stack__card:nth-child(3) { animation-delay: 0.11s; }
  .photo-stack__card:nth-child(4) { animation-delay: 0.14s; }
  .photo-stack__card:nth-child(5) { animation-delay: 0.17s; }
  .photo-stack__card:nth-child(n+6) { animation-delay: 0.2s; }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translate(var(--offset-x), var(--offset-y)) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translate(var(--offset-x), var(--offset-y)) scale(1);
    }
  }

  @keyframes cardInBase {
    from {
      opacity: 0;
      scale: 0.97;
    }
    to {
      opacity: 1;
      scale: 1;
    }
  }

  .photo-stack__card--base {
    position: relative;
    transform: none;
    height: 100%;
    width: auto;
    animation-name: cardInBase;
  }

  .photo-stack__card-inner {
    width: 100%;
    height: 100%;
    overflow: hidden;
    --pulse-scale: 1;
    --proximity-scale: 1;
    scale: calc(var(--pulse-scale) * var(--proximity-scale));
  }

  .photo-stack__card--base .photo-stack__card-inner img {
    height: 100%;
    width: auto;
    display: block;
  }

  .photo-stack__card:not(.photo-stack__card--base) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    --offset-x: var(--offset-x-m);
    --offset-y: var(--offset-y-m);
    transform: translate(var(--offset-x), var(--offset-y));
  }

  @media (min-width: 1201px) {
    .photo-stack__card:not(.photo-stack__card--base) {
      --offset-x: var(--offset-x-d);
      --offset-y: var(--offset-y-d);
    }
  }

  .photo-stack__card:not(.photo-stack__card--base) .photo-stack__card-inner img {
    width: 100%;
    height: 100%;
    object-fit: var(--fit-mode, cover);
    object-position: center;
    display: block;
  }
</style>

<script>
  import { initPhotoStack } from '@lib/animations/photoStack';
  import { initPhotoPulse } from '@lib/animations/photoPulse';
  import { initPhotoProximity } from '@lib/animations/photoProximity';

  const container = document.querySelector('[data-photo-stack]') as HTMLElement;
  const cards = Array.from(
    container?.querySelectorAll('.photo-stack__card') ?? []
  ) as HTMLElement[];
  const cardInners = Array.from(
    container?.querySelectorAll('.photo-stack__card-inner') ?? []
  ) as HTMLElement[];

  if (container && cards.length > 0) {
    initPhotoStack({ container, cards });
    initPhotoPulse({ cards: cardInners });
    initPhotoProximity({ cards: cardInners });
  }
</script>
