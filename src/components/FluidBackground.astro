---
// Global fluid simulation background — renders velocity field dashes on black
---

<div class="fluid-background" id="fluid-background">
  <canvas id="fluid-canvas"></canvas>
</div>

<script>
  // The fluid simulation is dynamically imported so it can be code-split
  // out of the critical-render-path bundle. On modern devices we still
  // load+init immediately (no perceptible delay vs static imports thanks
  // to Vite's automatic modulepreload). On low-end devices we wait for
  // requestIdleCallback so the page becomes interactive sooner — the
  // bg appears once the browser is otherwise idle.

  async function init() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const canvas = document.getElementById('fluid-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // Already initialized — persisted across navigation via transition:persist
    if ((canvas as any).__fluidSim) return;

    try {
      const [{ FluidSimulation }, { FLUID_CONFIG }] = await Promise.all([
        import('@lib/fluid/fluidSim'),
        import('@lib/fluid/config'),
      ]);

      // Re-check the persistence flag after async import — another page-load
      // race could have already initialized while we were awaiting.
      if ((canvas as any).__fluidSim) return;

      const isMobile = window.innerWidth < FLUID_CONFIG.MOBILE_BREAKPOINT;
      const sim = new FluidSimulation(canvas, isMobile);
      (canvas as any).__fluidSim = sim;

      if (!sim.isInitialized()) return;

      document.fonts.ready.then(() => {
        sim.start();
      });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          sim.pause();
        } else {
          sim.resume();
        }
      });

      let resizeTimeout: number;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = window.setTimeout(() => sim.resize(), 200);
      });
    } catch (e) {
      console.warn('Fluid background failed to initialize:', e);
    }
  }

  // Heuristic: defer init on low-end devices. hardwareConcurrency is
  // universal; deviceMemory and Network Information are Chromium-only and
  // safely undefined elsewhere (Safari users classified by core count alone).
  function shouldDefer(): boolean {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return true;
    const cores = navigator.hardwareConcurrency ?? 8;
    const mem = (navigator as unknown as { deviceMemory?: number }).deviceMemory;
    const conn = (navigator as unknown as { connection?: { saveData?: boolean; effectiveType?: string } }).connection;
    return (
      cores <= 4 ||
      (mem !== undefined && mem <= 4) ||
      conn?.saveData === true ||
      (conn?.effectiveType !== undefined && ['slow-2g', '2g'].includes(conn.effectiveType))
    );
  }

  if (shouldDefer()) {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => { void init(); }, { timeout: 2000 });
    } else {
      setTimeout(() => { void init(); }, 200);
    }
  } else {
    void init();
  }
</script>

<style>
  .fluid-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: var(--color-bg);
    pointer-events: none;
  }

  #fluid-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    #fluid-canvas {
      display: none;
    }
  }
</style>
