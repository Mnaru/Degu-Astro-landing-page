---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'section'> {
  class?: string;
}

const { class: className, ...attrs } = Astro.props;
---

<section class:list={['hero', className]} {...attrs}>
  <div class="hero-inner" data-gsap>
    <slot />
  </div>
</section>

<script>
  import { heroIntro } from '@lib/animations/heroIntro';
  import { heroOutro } from '@lib/animations/heroOutro';
  history.scrollRestoration = 'manual';
  await document.fonts.ready;
  document.querySelectorAll('.hero').forEach((el) => {
    heroIntro(el as HTMLElement, () => heroOutro(el as HTMLElement));
  });
</script>

<style>
  .hero {
    display: flex;
    width: 100%;
    min-height: 100vh;
    padding: max(15px, calc(10px + 1.389vw));
    background: red;
  }

  .hero-inner {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: grey;
  }

  .hero-inner :global(.hero-row) {
    display: flex;
    align-items: start;
    justify-content: center;
    gap: max(16px, calc(12.33px + 1.019vw));
    margin-top: clamp(12px, calc(10.67px + 0.37vw), 16px);
  }

  .hero-inner :global(.hero-row) > :global(.body-text-container) {
    margin-top: max(16px, calc(12.33px + 1.019vw));
  }

  .hero-inner :global(.scroll-hint) {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
  }
</style>
