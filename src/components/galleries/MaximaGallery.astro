---
import { Image } from 'astro:assets';
import { t } from '@i18n/utils';

import img01 from '@assets/images/galleries/maxima/01.png';
import img02 from '@assets/images/galleries/maxima/02.png';
import img03 from '@assets/images/galleries/maxima/03.png';
import img04 from '@assets/images/galleries/maxima/04.png';
import img05 from '@assets/images/galleries/maxima/05.png';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const i18n = t(locale);
const galleryName = i18n.galleries.maxima.name;
const images = [img01, img02, img03, img04, img05];
---

<section class="gallery gallery--infinite" data-gallery="maxima" id="gallery-maxima">
  <div class="gallery__scroll-track">
    {images.map((img, index) => (
      <div class="gallery__image-wrapper">
        <Image
          src={img}
          alt={`${galleryName} ${index + 1}`}
          width={1200}
          height={800}
          loading="eager"
        />
      </div>
    ))}
    {images.map((img, index) => (
      <div class="gallery__image-wrapper">
        <Image
          src={img}
          alt={`${galleryName} ${index + 1}`}
          width={1200}
          height={800}
          loading="lazy"
        />
      </div>
    ))}
  </div>
  <div class="gallery__name">{galleryName}</div>
  <a
    href={`/${locale}/gallery/maxima`}
    class="gallery__link"
    aria-label={`View ${galleryName} gallery`}
    data-astro-prefetch="hover"
  ></a>
</section>

<script>
  import { initGalleryScroll } from '@lib/animations/galleryScroll';
  import { initGalleryName } from '@lib/animations/galleryName';

  const gallery = document.querySelector('[data-gallery="maxima"]') as HTMLElement;
  const track = gallery?.querySelector('.gallery__scroll-track') as HTMLElement;
  const name = gallery?.querySelector('.gallery__name') as HTMLElement;

  if (track) {
    initGalleryScroll({ container: track, speed: 60, direction: 'left' });
  }
  if (gallery && name) {
    initGalleryName({ galleryEl: gallery, nameEl: name });
  }
</script>

<style>
  .gallery {
    position: relative;
    width: 100%;
    height: 100vh;
    padding: 12px 0;
    overflow: hidden;
    touch-action: pan-y;
    will-change: transform;
    transform-origin: center center;
  }

  .gallery__scroll-track {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--gallery-gap);
    height: 100%;
    align-items: stretch;
    will-change: transform;
    padding-left: 12px;
  }

  .gallery__image-wrapper {
    flex: 0 0 auto;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery__image-wrapper img {
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .gallery__image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--gallery-overlay-opacity));
    pointer-events: none;
    transition: background 0.3s ease;
  }

  .gallery:hover .gallery__image-wrapper::after {
    background: rgba(0, 0, 0, 0);
  }

  .gallery__name {
    position: absolute;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    pointer-events: none;
    display: none;
    font-family: var(--font-display);
    font-size: max(100px, calc(66.67px + 9.26vw));
    font-weight: 390;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: 1;
  }

  .gallery__link {
    position: absolute;
    inset: 0;
    z-index: 5;
    cursor: pointer;
  }

  @media (max-width: 1200px) {
    .gallery {
      height: auto;
      padding: 12px 0;
    }

    .gallery__scroll-track {
      align-items: stretch;
      padding-left: 0;
    }

    .gallery__image-wrapper {
      flex: 0 0 auto;
      width: auto;
      height: calc(95vw * (1400 / 1120));
    }

    .gallery__image-wrapper img {
      width: auto;
      height: 100%;
    }
  }
</style>
