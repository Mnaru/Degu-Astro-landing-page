---
import { Image } from 'astro:assets';
import { t } from '@i18n/utils';

import img01 from '@assets/images/galleries/alita-2/Alita2_01.png';
import img02 from '@assets/images/galleries/alita-2/Alita2_02.png';
import img03 from '@assets/images/galleries/alita-2/Alita2_03.png';
import img04 from '@assets/images/galleries/alita-2/Alita2_04.png';
import img05 from '@assets/images/galleries/alita-2/Alita2_05.png';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const i18n = t(locale);
const galleryName = i18n.galleries['alita-2'].name;
const images = [img01, img02, img03, img04, img05];
---

<section class="gallery gallery--infinite" data-gallery="alita-2" id="gallery-alita-2">
  <div class="gallery__scroll-track">
    {images.map((img, index) => (
      <div class="gallery__image-wrapper">
        <Image
          src={img}
          alt={`${galleryName} ${index + 1}`}
          width={1200}
          height={800}
          loading="lazy"
        />
      </div>
    ))}
    {images.map((img, index) => (
      <div class="gallery__image-wrapper">
        <Image
          src={img}
          alt={`${galleryName} ${index + 1}`}
          width={1200}
          height={800}
          loading="lazy"
        />
      </div>
    ))}
  </div>
  <div class="gallery__name">{galleryName}</div>
  <a
    href={`/${locale}/gallery/alita-2`}
    class="gallery__link"
    aria-label={`View ${galleryName} gallery`}
    data-astro-prefetch="hover"
  ></a>
</section>

<script>
  import { initGalleryScroll } from '@lib/animations/galleryScroll';
  import { initGalleryName } from '@lib/animations/galleryName';
  import { registerCleanup } from '@lib/animations/lifecycle';

  document.addEventListener('astro:page-load', () => {
    const gallery = document.querySelector('[data-gallery="alita-2"]') as HTMLElement;
    if (!gallery || (gallery as any).__galleryInit) return;
    (gallery as any).__galleryInit = true;
    const track = gallery.querySelector('.gallery__scroll-track') as HTMLElement;
    const name = gallery.querySelector('.gallery__name') as HTMLElement;
    if (track) registerCleanup(initGalleryScroll({ container: track, speed: 60, direction: 'left' }), { persistent: true });
    if (name) registerCleanup(initGalleryName({ galleryEl: gallery, nameEl: name }), { persistent: true });
  });
</script>

<style>
  .gallery {
    position: relative;
    width: 100%;
    height: 100vh;
    padding: 12px 0;
    overflow: hidden;
    touch-action: pan-y;
    will-change: transform;
    transform-origin: center center;
  }

  .gallery__scroll-track {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--gallery-gap);
    height: 100%;
    align-items: stretch;
    will-change: transform;
    padding-left: 12px;
  }

  .gallery__image-wrapper {
    flex: 0 0 auto;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery__image-wrapper img {
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .gallery__image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--gallery-overlay-opacity));
    pointer-events: none;
    transition: background 0.6s ease-out;
  }

  .gallery:hover .gallery__image-wrapper::after {
    background: rgba(0, 0, 0, 0);
  }

  .gallery__name {
    position: absolute;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    pointer-events: none;
    display: none;
    font-family: var(--font-display);
    font-size: max(100px, calc(66.67px + 9.26vw));
    font-weight: 390;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: 1;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
  }

  .gallery__link {
    position: absolute;
    inset: 0;
    z-index: 5;
    cursor: pointer;
  }

  @media (max-width: 1200px) {
    .gallery {
      height: auto;
      padding: 12px 0;
    }

    .gallery__scroll-track {
      align-items: stretch;
      padding-left: 0;
    }

    .gallery__image-wrapper {
      flex: 0 0 95vw;
      width: 95vw;
      height: auto;
    }

    .gallery__image-wrapper img {
      width: 100%;
      height: auto;
    }
  }
</style>
