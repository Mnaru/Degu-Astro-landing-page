---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { t } from '@i18n/utils';

import eckes02 from '@assets/images/galleries/eckes-granini/Eckes_02.png';
import eckes04 from '@assets/images/galleries/eckes-granini/Eckes_04.png';
import eckes06 from '@assets/images/galleries/eckes-granini/Eckes_06.png';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const i18n = t(locale);
const galleryName = i18n.galleries['eckes-granini'].name;

type HomeMedia =
  | { kind: 'image'; src: ImageMetadata; alt: string }
  | { kind: 'video'; playbackId: string; alt: string };

const mediaItems: HomeMedia[] = [
  { kind: 'video', playbackId: 'ZjZlATUFk01g9dX8ILrKQ00wZqUVQipg79MBG6VXFFCJg', alt: `${galleryName} video 1` },
  { kind: 'image', src: eckes06, alt: `${galleryName} 1` },
  { kind: 'video', playbackId: '14E5o7fTxLPNZLbgPSOHimIJ9o201y02HOR8X41gPV01H8', alt: `${galleryName} video 2` },
  { kind: 'image', src: eckes04, alt: `${galleryName} 2` },
  { kind: 'video', playbackId: 'Y5eDdnqx5oUx3aS3mGFw101xZXnHD01CmXPKzRvK3WSrc', alt: `${galleryName} video 3` },
  { kind: 'image', src: eckes02, alt: `${galleryName} 3` },
];

const loop = [...mediaItems, ...mediaItems];
---

<section class="gallery gallery--infinite" data-gallery="eckes-granini" id="gallery-eckes-granini">
  <div class="gallery__scroll-track">
    {loop.map((item) => (
      <div class:list={['gallery__image-wrapper', { 'gallery__image-wrapper--video': item.kind === 'video' }]}>
        {item.kind === 'image' ? (
          <Image
            src={item.src}
            alt={item.alt}
            widths={[400, 800, 1200, 1600]}
            sizes="(max-width: 1200px) 95vw, 50vw"
            loading="lazy"
          />
        ) : (
          <>
            <img
              class="gallery__poster"
              src={`https://image.mux.com/${item.playbackId}/thumbnail.webp?time=0`}
              alt=""
              loading="eager"
              decoding="async"
              aria-hidden="true"
            />
            <mux-video
              playback-id={item.playbackId}
              poster={`https://image.mux.com/${item.playbackId}/thumbnail.webp?time=0`}
              muted
              autoplay
              loop
              playsinline
              preload="auto"
              aria-label={item.alt}
            ></mux-video>
          </>
        )}
      </div>
    ))}
  </div>
  <div class="gallery__name" transition:name="gallery-name-eckes-granini">{galleryName}</div>
  <a
    href={`/${locale}/gallery/eckes-granini`}
    class="gallery__link"
    aria-label={`View ${galleryName} gallery`}
    data-astro-prefetch="viewport"
  ></a>
</section>

<script>
  import { initGalleryScroll } from '@lib/animations/galleryScroll';
  import { initGalleryName } from '@lib/animations/galleryName';
  import { registerCleanup } from '@lib/animations/lifecycle';

  document.addEventListener('astro:page-load', () => {
    const gallery = document.querySelector('[data-gallery="eckes-granini"]') as HTMLElement;
    if (!gallery || (gallery as any).__galleryInit) return;
    (gallery as any).__galleryInit = true;
    const track = gallery.querySelector('.gallery__scroll-track') as HTMLElement;
    const name = gallery.querySelector('.gallery__name') as HTMLElement;
    if (track) registerCleanup(initGalleryScroll({ container: track, speed: 60, direction: 'left' }), { persistent: true });
    if (name) registerCleanup(initGalleryName({ galleryEl: gallery, nameEl: name }), { persistent: true });

    const observer = new IntersectionObserver((entries, obs) => {
      if (entries.some(e => e.isIntersecting)) {
        import('@mux/mux-video');
        obs.disconnect();
      }
    }, { rootMargin: '200px 0px' });
    observer.observe(gallery);
    registerCleanup(() => observer.disconnect(), { persistent: true });

    gallery.querySelectorAll<HTMLElement>('mux-video').forEach(video => {
      const onPlay = () => video.classList.add('is-playing');
      video.addEventListener('playing', onPlay, { once: true });
      registerCleanup(() => video.removeEventListener('playing', onPlay), { persistent: true });
    });
  });
</script>

<style>
  .gallery {
    position: relative;
    width: 100%;
    height: 100vh;
    padding: 12px 0;
    overflow: hidden;
    touch-action: pan-y;
    will-change: transform;
    transform-origin: center center;
  }

  .gallery__scroll-track {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--gallery-gap);
    height: 100%;
    align-items: stretch;
    will-change: transform;
    padding-left: 12px;
  }

  .gallery__image-wrapper {
    flex: 0 0 auto;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery__image-wrapper img {
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .gallery__image-wrapper--video {
    position: relative;
    aspect-ratio: 4 / 5;
  }

  .gallery__image-wrapper--video .gallery__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
  }

  .gallery__image-wrapper--video mux-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.15s linear;
    --media-object-fit: cover;
    --media-object-position: center;
    --controls: none;
  }

  .gallery__image-wrapper--video mux-video.is-playing {
    opacity: 1;
  }

  .gallery__image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--gallery-overlay-opacity));
    pointer-events: none;
    transition: background 0.6s ease-out;
    z-index: 2;
  }

  .gallery:hover .gallery__image-wrapper::after {
    background: rgba(0, 0, 0, 0);
  }

  .gallery__name {
    position: absolute;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    pointer-events: none;
    display: none;
    font-family: var(--font-display);
    font-size: max(100px, calc(66.67px + 9.26vw));
    font-weight: 390;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: 1;
    white-space: nowrap;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
  }

  .gallery__link {
    position: absolute;
    inset: 0;
    z-index: 5;
    cursor: pointer;
  }

  @media (max-width: 1200px) {
    .gallery {
      height: auto;
      padding: 12px 0;
    }

    .gallery__scroll-track {
      align-items: stretch;
      padding-left: 0;
    }

    .gallery__image-wrapper {
      flex: 0 0 95vw;
      width: 95vw;
      height: auto;
    }

    .gallery__image-wrapper img {
      width: 100%;
      height: auto;
    }

    .gallery__image-wrapper--video {
      aspect-ratio: 3 / 2;
    }
  }
</style>
