---
import { Image } from 'astro:assets';
import { t } from '@i18n/utils';

import img01 from '@assets/images/galleries/open24/Open_01.png';
import img02 from '@assets/images/galleries/open24/Open_02.png';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const i18n = t(locale);
const galleryName = i18n.galleries.open24.name;
const images = [img01, img02];
---

<section class="gallery gallery--static" data-gallery="open24" id="gallery-open24">
  <div class="gallery__images">
    <div class="gallery__image-wrapper">
      <Image
        src={images[0]}
        alt={`${galleryName} 1`}
        width={1200}
        height={800}
        loading="lazy"
      />
    </div>
    <div class="gallery__image-wrapper">
      <Image
        src={images[1]}
        alt={`${galleryName} 2`}
        width={1200}
        height={800}
        loading="lazy"
      />
    </div>
  </div>
  <div class="gallery__name" transition:name="gallery-name-open24">{galleryName}</div>
  <a
    href={`/${locale}/gallery/open24`}
    class="gallery__link"
    aria-label={`View ${galleryName} gallery`}
    data-astro-prefetch="viewport"
  ></a>
</section>

<script>
  import { initGalleryName } from '@lib/animations/galleryName';
  import { registerCleanup } from '@lib/animations/lifecycle';

  document.addEventListener('astro:page-load', () => {
    const gallery = document.querySelector('[data-gallery="open24"]') as HTMLElement;
    if (!gallery || (gallery as any).__galleryInit) return;
    (gallery as any).__galleryInit = true;
    const name = gallery.querySelector('.gallery__name') as HTMLElement;
    if (name) registerCleanup(initGalleryName({ galleryEl: gallery, nameEl: name }), { persistent: true });
  });
</script>

<style>
  .gallery {
    position: relative;
    width: 100%;
    height: calc((960 / 1440) * 100vw);
    padding: 0;
    overflow: hidden;
    will-change: transform;
    transform-origin: center center;
  }

  .gallery__images {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--gallery-gap);
    height: 100%;
  }

  .gallery__image-wrapper {
    position: relative;
    overflow: hidden;
    width: calc((100% - var(--gallery-gap)) / 2);
    height: 100%;
    flex-shrink: 0;
  }

  .gallery__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .gallery__image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--gallery-overlay-opacity));
    pointer-events: none;
    transition: background 0.6s ease-out;
  }

  .gallery:hover .gallery__image-wrapper::after {
    background: rgba(0, 0, 0, 0);
  }

  .gallery__name {
    position: absolute;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    pointer-events: none;
    display: none;
    font-family: var(--font-display);
    font-size: max(100px, calc(66.67px + 9.26vw));
    font-weight: 390;
    text-transform: uppercase;
    color: var(--color-white);
    line-height: 1;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
  }

  .gallery__link {
    position: absolute;
    inset: 0;
    z-index: 5;
    cursor: pointer;
  }

  @media (max-width: 1200px) {
    .gallery {
      height: 100vh;
      padding: 0;
    }

    .gallery__images {
      gap: 0;
      height: 100%;
    }

    .gallery__image-wrapper {
      width: 100%;
      height: 100%;
    }

    .gallery__image-wrapper:nth-child(2) {
      display: none;
    }
  }
</style>
