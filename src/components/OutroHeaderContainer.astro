---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  text: string;
  class?: string;
}

const { text, class: className, ...attrs } = Astro.props;
---

<div class:list={['outro-header-container', className]} {...attrs}>
  <span class="outro-header-text">{text}</span>
</div>

<style>
  .outro-header-container {
    width: fit-content;
  }

  .outro-header-text {
    display: block;
    font-family: var(--font-display);
    font-size: max(140px, calc(103.33px + 10.185vw));
    font-style: normal;
    font-weight: 400;
    line-height: 0.75;
    text-align: left;
    text-transform: uppercase;
    color: var(--color-offwhite);
    white-space: nowrap;
    text-box-trim: both;
    text-box-edge: cap;
  }
</style>
