---
import type { HTMLAttributes } from 'astro/types';
import { Image } from 'astro:assets';
import teamPhoto from '../assets/images/team/TeamPhoto.png';
import { t } from '@i18n/utils';

interface Props extends HTMLAttributes<'section'> {
  locale: string;
  class?: string;
}

const { locale, class: className, ...attrs } = Astro.props;
const i18n = t(locale);
---

<section class:list={['outro', className]} {...attrs}>
  <div class="outro-inner">
    <slot />
    <Image src={teamPhoto} alt={i18n.outro.teamImageAlt} class="team-photo" />
  </div>
</section>

<style>
  .outro {
    display: flex;
    width: 100%;
    min-height: 100vh;
    padding-top: max(15px, calc(10px + 1.389vw));
    padding-right: max(15px, calc(10px + 1.389vw));
    padding-bottom: max(calc(72.67px - 2.963vw), calc(10px + 1.389vw));
    padding-left: max(15px, calc(10px + 1.389vw));
    /* background: red; */
  }

  .outro-inner {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* background: grey; — temporarily removed */
  }

  .team-photo {
    position: absolute;
    right: calc(-235.68px + 45.181vw);
    top: calc(50% - 140px + 4.167vw);
    transform: rotate(10.86deg);
    width: calc(287.56px - 2.608vw);
    height: auto;
  }

  .outro-inner :global(.outro-content) {
    width: fit-content;
    margin-inline: auto;
  }

  @media (max-width: 500px) {
    .outro-inner :global(.outro-content) {
      margin-inline: 0;
    }
  }

  .outro-inner :global(.outro-body) {
    margin-top: clamp(56px, calc(421.33px - 25.37vw), 330px);
  }

  .outro-inner :global(.outro-buttons) {
    display: flex;
    flex-direction: row;
    gap: 12px;
    margin-top: 27px;
  }
</style>
