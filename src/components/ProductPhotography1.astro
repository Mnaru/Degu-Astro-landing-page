---
import { Image } from 'astro:assets';
import img1 from '../assets/images/gallery/product-photography/product-photography-1.png';
import img2 from '../assets/images/gallery/product-photography/product-photography-2.png';
import img3 from '../assets/images/gallery/product-photography/product-photography-3.png';
import img4 from '../assets/images/gallery/product-photography/product-photography-4.png';
import img5 from '../assets/images/gallery/product-photography/product-photography-5.png';

const images = [img1, img2, img3, img4, img5];
---

<section class="social-media-gallery">
  <div class="social-media-gallery__label">
    <div class="gallery-label">
      <div class="gallery-label__row">
        <span class="gallery-label-text">Product</span>
        <span class="gallery-label-subtext">for Mainilla<br>(XXXX)</span>
      </div>
      <span class="gallery-label-text">photography</span>
    </div>
  </div>
  <div class="social-media-gallery__track">
    {images.map((img, i) => (
      <div class="social-media-gallery__item">
        <Image src={img} alt={`Social media ${i + 1}`} />
      </div>
    ))}
  </div>
</section>

<style>
  .social-media-gallery {
    position: relative;
    display: block;
    width: max-content;
    height: 100vh;
    background: #7F8997;
  }

  .social-media-gallery__label {
    position: absolute;
    top: 30px;
    left: 30px;
    z-index: 1;
  }

  .gallery-label-text {
    color: var(--color-black);
    font-family: "Anton SC";
    font-size: max(50px, calc(32.33px + 4.907vw));
    font-style: normal;
    font-weight: 400;
    line-height: max(46px, calc(29.83px + 4.526vw));
    text-transform: uppercase;
  }

  .gallery-label-subtext {
    display: inline-block;
    vertical-align: top;
    margin-left: calc(10.67px + 0.926vw);
    color: var(--color-black);
    font-family: "Instrument Serif";
    font-size: max(18px, calc(11.67px + 1.759vw));
    font-style: italic;
    font-weight: 400;
    line-height: 1;
  }

  .social-media-gallery__track {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    padding-top: max(12px, calc(44px - 2.222vw));
    height: 100%;
    box-sizing: border-box;
  }

  .social-media-gallery__item {
    flex-shrink: 0;
    height: clamp(45%, calc(196px + 46.296vw), 100%);
    width: fit-content;
    border-radius: 5px;
    overflow: hidden;
    view-timeline-name: --item;
    view-timeline-axis: inline;
    animation: item-focus linear both;
    animation-timeline: --item;
  }

  .social-media-gallery__item img {
    height: 100%;
    width: auto;
    display: block;
    scale: 1.15;
    animation: inner-parallax linear both;
    animation-timeline: --item;
  }

  @keyframes item-focus {
    0%, 100% { scale: 0.95; opacity: 0.65; }
    40%, 60%  { scale: 1; opacity: 1; }
  }

  @keyframes inner-parallax {
    from { translate: 5% 0; }
    to   { translate: -5% 0; }
  }
</style>
