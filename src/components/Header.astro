---
import type { HTMLAttributes } from 'astro/types';
import DeguLogo from './DeguLogo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props extends HTMLAttributes<'header'> {
  locale: string;
  class?: string;
}

const { locale, class: className, ...attrs } = Astro.props;
---

<header class:list={['site-header', className]} {...attrs}>
  <LanguageSwitcher currentLocale={locale} />
  <DeguLogo />
</header>

<script>
  import { registerCleanup } from '@lib/animations/lifecycle';

  document.addEventListener('astro:page-load', () => {
    const header = document.querySelector<HTMLElement>('.site-header');
    const vv = window.visualViewport;
    if (!header || !vv) return;

    let rafId = 0;
    const sync = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        header.style.transform = `translateY(${vv.offsetTop}px)`;
        rafId = 0;
      });
    };

    vv.addEventListener('resize', sync);
    vv.addEventListener('scroll', sync);
    sync();

    registerCleanup(() => {
      vv.removeEventListener('resize', sync);
      vv.removeEventListener('scroll', sync);
      if (rafId) cancelAnimationFrame(rafId);
      header.style.transform = '';
    });
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    padding: max(15px, calc(10px + 1.389vw));
    padding-bottom: 0;
    pointer-events: none;
  }

  .site-header :global(*) {
    pointer-events: auto;
  }

</style>
